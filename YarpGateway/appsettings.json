{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "Yarp": "Information"
        }
    },

    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Yarp": "Information"
            }
        }
    },

    "ReverseProxy": {
        "Routes": {
            // 1. Swagger - самый специфичный маршрут
            "test-service-swagger": {
                "ClusterId": "test-service-cluster",
                "Match": {
                    "Path": "/api/test/{any:regex(swagger|openapi)}/{**catchall}"
                },
                "Transforms": [
                    { "PathPattern": "/{any}/{catchall}" }
                ]
            },
            // 2. Auth - более специфичный чем products
            "test-service-auth": {
                "ClusterId": "test-service-cluster",
                "Match": {
                    "Path": "/api/test/auth/{**catchall}"
                },
                "Transforms": [
                    { "PathPattern": "/auth/{catchall}" }
                ]
            },
            // 3. Products - общий маршрут для продуктов
            "test-service-products": {
                "ClusterId": "test-service-cluster",
                "Match": {
                    "Path": "/api/test/products/{**catchall}"
                },
                "Transforms": [
                    { "PathPattern": "/products/{catchall}" }
                ]
            },
            // 4. Keycloak - должен идти после /api/test маршрутов
            "keycloak-route": {
                "ClusterId": "keycloak-cluster",
                "Match": {
                    "Path": "/auth/{**catchall}"
                },
                "Transforms": [
                    { "PathPattern": "/{catchall}" }
                ]
            }
        },
        "Clusters": {
            "test-service-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://internetshop-test-api:8080/"
                    }
                },
                "HttpClient": {
                    "Timeout": "00:01:00"
                }
            },
            "keycloak-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://internetshop-keycloak:8080/"
                    }
                },
                "HttpClient": {
                    "Timeout": "00:01:00"
                }
            }
        }
    }
}